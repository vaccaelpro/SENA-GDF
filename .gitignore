# ============================================
# .gitignore — Proyecto SENA-GDF (Monorepo)
# Backend: Node.js / Express / MySQL
# Frontend: React (Create React App)
# ============================================

# -------------------- Dependencias --------------------
# Ignorar node_modules en TODAS las ubicaciones
node_modules/
**/node_modules/

# Package manager lock files alternativos (mantener package-lock.json)
yarn.lock
pnpm-lock.yaml

# PnP (Plug'n'Play) de Yarn
.pnp
.pnp.js
.pnp.cjs

# -------------------- Variables de entorno --------------------
# ⚠️ NUNCA subir archivos .env con secretos (credenciales BD, emails, API keys)
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
backend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# -------------------- Build / Producción --------------------
# Frontend build output (React CRA)
frontend/build/
build/
dist/

# -------------------- Testing --------------------
# Coverage reports
coverage/
frontend/coverage/
backend/coverage/

# -------------------- Logs --------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
logs/

# -------------------- Docker --------------------
# No ignorar Dockerfile, pero sí artefactos de Docker
docker-compose.override.yml
.docker/

# -------------------- IDEs y editores --------------------
# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/extensions.json

# IntelliJ IDEA / WebStorm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# -------------------- Sistema operativo --------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.nfs*

# -------------------- Temporales / Caché --------------------
*.tmp
*.temp
*.swp
*.swo
*.bak
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Scratch / archivos temporales del proyecto
backend/scratch/
scratch/

# -------------------- Misceláneos --------------------
# Archivos comprimidos generados
*.tgz
*.tar.gz
*.zip

# Certificados SSL locales
*.pem
*.key
*.crt

# Reporte de errores de compilación
tsconfig.tsbuildinfo
